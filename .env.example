# ============================================================
# SF City Intelligence — Agent Scraper Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# aperture-nexus agent authentication (required for storage)
# Run `python provisioning.py` once to register all agents in ApertureDB,
# then set NEXUS_API_KEY to the key printed by that script.
# All agents share one key but retain separate user_id identities.
NEXUS_API_KEY=your_nexus_api_key_here

# ------------------------------------------------------------------
# ApertureDB connection (required for storage)
# Option A — encoded key (preferred):
APERTUREDB_KEY=your_aperturedb_key_here
# Option B — individual fields:
# APERTUREDB_HOST=localhost
# APERTUREDB_PORT=55555
# APERTUREDB_USER=admin
# APERTUREDB_PASSWORD=your_password_here

# ------------------------------------------------------------------
# aperture-nexus config (optional — uses defaults if omitted)
# APERTURE_NEXUS_CONFIG=../aperture-nexus/aperture_nexus.json

# ------------------------------------------------------------------
# Yelp Fusion API
# Get your key at: https://docs.developer.yelp.com/
# Create an app → copy the "API Key" from the app page.
YELP_API_KEY=your_yelp_api_key_here

# ------------------------------------------------------------------
# 511 SF Bay API
# Register at: https://511.org/open-data/token
# Instant self-registration, key emailed immediately.
FIVE_ONE_ONE_API_KEY=your_511_api_key_here

# ------------------------------------------------------------------
# AirNow API
# Register at: https://docs.airnowapi.org/
# Instant signup — key available immediately after registration.
AIRNOW_API_KEY=your_airnow_api_key_here

# ------------------------------------------------------------------
# Mapillary API (replaces Flickr — free, no Pro account required)
# 1. Sign up at https://www.mapillary.com
# 2. Go to Dashboard → Applications → Register application
# 3. Copy the "Client Token" shown on the app page.
MAPILLARY_API_KEY=your_mapillary_client_token_here

# ------------------------------------------------------------------
# Reddit (no credentials required)
# Reddit's public JSON API is freely accessible for public subreddits.
# No OAuth app, no Devvit, no approval needed.
# Only a descriptive User-Agent is required (customize with your project name).
REDDIT_USER_AGENT=sf-city-intelligence-bot/1.0

# ------------------------------------------------------------------
# Image storage behaviour (optional — default is true)
# true  → image bytes are downloaded and stored in ApertureDB (full multimodal)
# false → only the image URL + metadata are stored (lighter, faster for testing)
# STORE_IMAGE_BYTES=true

# ------------------------------------------------------------------
# OpenAI (optional — enables richer chat responses + image recognition)
# Without this, chat returns template messages and image endpoint uses
# CLIP similarity only. With it, GPT-4o generates responses and identifies images.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ------------------------------------------------------------------
# REST API server (optional — these are the defaults)
# API_HOST=0.0.0.0
# API_PORT=8000

# ------------------------------------------------------------------
# Scheduler settings (optional — these are the defaults)
# LIVE_INTERVAL_SECONDS=300          # 5 minutes for live agents
# STATIC_INTERVAL_SECONDS=86400      # 24 hours for static agents
# LOG_LEVEL=INFO
